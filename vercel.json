{
  "builds": [
    {
      "src": "web/routes.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "web/routes.py" },
    { "src": "/(.*)", "dest": "web/routes.py" }
  ],
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_MODEL": "deepseek-v4-flash"
  }
}
